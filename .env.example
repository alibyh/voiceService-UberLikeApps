# Copy this file to `.env` and fill in your secrets.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

RERANKER_MODEL=claude-haiku-4-5
EMBEDDING_MODEL=BAAI/bge-m3

# ASR backend selection. "whisper" uses OpenAI Whisper, "deepgram" uses
# Deepgram with first-class keyword boosting (better for proper nouns).
ASR_BACKEND=deepgram
ASR_MODEL=whisper-1
DEEPGRAM_MODEL=nova-2-general

PLACES_PATH=matcher/data/places.json
INDEX_DIR=matcher/data/index

CONFIDENCE_THRESHOLD=0.85
CONFIDENCE_MARGIN=0.1

LOG_FILE=logs/resolutions.jsonl
